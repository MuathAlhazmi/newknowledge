generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  INSTRUCTOR
  PARTICIPANT
}

enum EnrollmentStatus {
  PENDING
  APPROVED
}

enum ExamType {
  PRE
  POST
}

/** صلاحيات العضو في فريق تدريس الدورة */
enum CourseInstructorRole {
  OWNER
  EDITOR
  VIEWER
}

enum AnnouncementKind {
  MANUAL
  CONTENT
  QUIZ
  ZOOM
}

enum CompletionMethod {
  AUTO
  ADMIN
}

enum QuestionKind {
  MCQ
  SHORT_ANSWER
}

enum ExamAttemptStatus {
  DRAFT
  PENDING_MANUAL
  COMPLETE
}

enum ShowSolutionsAfter {
  NEVER
  AFTER_SUBMIT
  AFTER_ATTEMPT_END
}

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  phone              String             @unique
  role               UserRole
  platformApproved   Boolean            @default(false)
  enrollments        Enrollment[]
  examAttempts       ExamAttempt[]
  sentMessages       ChatMessage[]      @relation("SentMessages")
  receivedMessages   ChatMessage[]      @relation("ReceivedMessages")
  feedbacks          Feedback[]
  postExamApprovals  PostExamApproval[]
  courseGrades       CourseGrade[]
  courseInstructors  CourseInstructor[]
  announcements      Announcement[]     @relation("AnnouncementAuthor")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  approvedPostExams  PostExamApproval[] @relation("ApprovedBy")
  materialProgress   MaterialProgress[]
  courseCompletions  CourseCompletion[]
}

model Course {
  id               String              @id @default(cuid())
  title            String
  description      String
  enrollments      Enrollment[]
  materials        Material[]
  exams            Exam[]
  zoomSessions     ZoomSession[]
  feedbacks        Feedback[]
  grades           CourseGrade[]
  postExamApprovals PostExamApproval[]
  gradingConfig    GradingConfig?
  courseInstructors CourseInstructor[]
  announcements     Announcement[]
  courseCompletions CourseCompletion[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model Announcement {
  id          String           @id @default(cuid())
  courseId    String
  createdById String
  kind        AnnouncementKind @default(MANUAL)
  title       String
  body        String?
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("AnnouncementAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([courseId, publishedAt])
  @@index([courseId, createdAt])
}

model CourseInstructor {
  id        String                 @id @default(cuid())
  courseId  String
  userId    String
  role      CourseInstructorRole     @default(EDITOR)
  course    Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime               @default(now())

  @@unique([courseId, userId])
}

model Enrollment {
  id         String           @id @default(cuid())
  userId     String
  courseId   String
  status     EnrollmentStatus @default(PENDING)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([userId, courseId])
}

model Material {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  pdfPath     String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    MaterialProgress[]
  createdAt   DateTime @default(now())
}

model MaterialProgress {
  id            String    @id @default(cuid())
  userId        String
  materialId    String
  firstOpenedAt DateTime  @default(now())
  completedAt   DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  material      Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([userId, materialId])
  @@index([userId, materialId])
}

model CourseCompletion {
  id                String           @id @default(cuid())
  userId            String
  courseId          String
  completedAt       DateTime         @default(now())
  certificateNumber String           @unique
  method            CompletionMethod @default(AUTO)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Exam {
  id                     String             @id @default(cuid())
  courseId               String
  type                   ExamType
  title                  String
  durationMinutes        Int
  isActive               Boolean            @default(true)
  shuffleQuestions       Boolean            @default(false)
  shuffleChoices         Boolean            @default(false)
  maxAttempts            Int?
  reviewWindowMinutes    Int?
  showSolutionsAfter     ShowSolutionsAfter @default(NEVER)
  allowReviewWhileAttempt Boolean           @default(true)
  course                 Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions              Question[]
  attempts               ExamAttempt[]
  createdAt              DateTime           @default(now())

  @@unique([courseId, type])
}

model Question {
  id           String       @id @default(cuid())
  examId       String
  text         String
  order        Int
  kind         QuestionKind @default(MCQ)
  points       Int          @default(1)
  rubric       String?
  exam         Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  choices      Choice[]
}

model Choice {
  id           String    @id @default(cuid())
  questionId   String
  text         String
  isCorrect    Boolean   @default(false)
  question     Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id                   String             @id @default(cuid())
  userId               String
  examId               String
  attemptNumber        Int                @default(1)
  status               ExamAttemptStatus  @default(DRAFT)
  startedAt            DateTime           @default(now())
  submittedAt          DateTime?
  score                Float?
  manualScore          Float?
  shortAnswerScoresJson String?
  answersJson          String?
  shuffleSeed          String?
  layoutJson           String?
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam                 Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId, examId])
}

model PostExamApproval {
  id           String    @id @default(cuid())
  userId       String
  courseId     String
  approvedById String
  approvedAt   DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  approvedBy   User      @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model ChatMessage {
  id          String    @id @default(cuid())
  courseId    String
  senderId    String
  receiverId  String
  text        String
  createdAt   DateTime  @default(now())
  sender      User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Feedback {
  id          String    @id @default(cuid())
  courseId    String
  userId      String
  text        String
  createdAt   DateTime  @default(now())
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseGrade {
  id            String    @id @default(cuid())
  courseId       String
  userId         String
  preScore       Float?
  postScore      Float?
  finalScore     Float?
  isPassed       Boolean?
  updatedByAdmin Boolean   @default(false)
  course         Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@unique([courseId, userId])
}

model GradingConfig {
  id             String   @id @default(cuid())
  courseId       String   @unique
  preWeight      Int
  postWeight     Int
  passThreshold  Int
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ZoomSession {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  meetingUrl  String
  startsAt    DateTime
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
